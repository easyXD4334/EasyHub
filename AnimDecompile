		textBox.TextEditable = true
		textBox.BorderSizePixel = 0
		textBox.LayoutOrder = 2
		textBox.Parent = chunkFrame
		local tc = Instance.new('UICorner')
		tc.CornerRadius = UDim.new(0, 6)
		tc.Parent = textBox
		local tp = Instance.new('UIPadding')
		tp.PaddingTop = UDim.new(0, 8)
		tp.PaddingBottom = UDim.new(0, 8)
		tp.PaddingLeft = UDim.new(0, 10)
		tp.PaddingRight = UDim.new(0, 10)
		tp.Parent = textBox
		local spacer = Instance.new('Frame')
		spacer.Name = 'Spacer'
		spacer.Size = UDim2.new(1, 0, 0, 8)
		spacer.BackgroundTransparency = 1
		spacer.LayoutOrder = 3
		spacer.Parent = chunkFrame
		local chunkLayout = Instance.new('UIListLayout')
		chunkLayout.SortOrder = Enum.SortOrder.LayoutOrder
		chunkLayout.Padding = UDim.new(0, 0)
		chunkLayout.Parent = chunkFrame
		chunkFrame.Parent = scrollFrame
		chunkFrame.BackgroundTransparency = 1
		TweenService:Create(chunkFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {BackgroundTransparency = 0}):Play()
		return chunkFrame
	end
	
	local function splitIntoChunks(text, chunkSize)
		local chunks = {}
		local len = #text
		for i = 1, len, chunkSize do
			table.insert(chunks, text:sub(i, math.min(i + chunkSize - 1, len)))
		end
		return chunks
	end
	
	-- ==============================
	-- Button hover effects
	-- ==============================
	convertBtn.MouseEnter:Connect(function()
		if not isConverting then
			TweenService:Create(convertBtn, TweenInfo.new(0.2), {Size = UDim2.new(0, 166, 1, 4)}):Play()
		end
	end)
	convertBtn.MouseLeave:Connect(function()
		TweenService:Create(convertBtn, TweenInfo.new(0.2), {Size = UDim2.new(0, 160, 1, 0)}):Play()
	end)
	assetInput.Focused:Connect(function()
		local s = assetInput:FindFirstChildOfClass('UIStroke')
		if s then TweenService:Create(s, TweenInfo.new(0.2), {Color = Color3.fromRGB(100, 80, 220)}):Play() end
	end)
	assetInput.FocusLost:Connect(function()
		local s = assetInput:FindFirstChildOfClass('UIStroke')
		if s then TweenService:Create(s, TweenInfo.new(0.2), {Color = Color3.fromRGB(60, 60, 90)}):Play() end
	end)
	
	-- ==============================
	-- Convert button logic (all client-side)
	-- ==============================
	convertBtn.MouseButton1Click:Connect(function()
		if isConverting then return end
		local rawText = assetInput.Text
		local assetId = rawText:match('%d+')
		if not assetId then
			setStatus('Please enter a valid numeric Asset ID', Color3.fromRGB(255, 90, 90))
			return
		end
		isConverting = true
		clearOutput()
		convertBtn.Text = 'Converting...'
		TweenService:Create(convertBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 70)}):Play()
		setStatus('Fetching animation data for ID: ' .. assetId .. '...', Color3.fromRGB(255, 210, 80))
		task.wait()
		local success, result = pcall(function()
			return convertAnimation(tonumber(assetId))
		end)
		if success then
			local scriptText = result
			local chunks = splitIntoChunks(scriptText, CHUNK_SIZE)
			setStatus(string.format('Generated %s chars in %d chunk(s) - click textbox to select and copy', tostring(#scriptText), #chunks), Color3.fromRGB(100, 240, 150))
			for i, chunk in ipairs(chunks) do
				createChunkFrame(i, chunk, #chunks)
				if i % 3 == 0 then task.wait() end
			end
		else
			setStatus('Error: ' .. tostring(result), Color3.fromRGB(255, 90, 90))
		end
		convertBtn.Text = 'Convert'
		TweenService:Create(convertBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(100, 70, 220)}):Play()
		isConverting = false
	end)
	
	print('[AnimToScript] Client-only UI ready - press P to toggle visibility')
end;
task.spawn(C_18);

return G2L["1"], require;
