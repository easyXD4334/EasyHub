	-- ==============================
	-- Serialization helpers
	-- ==============================
	local function serializeCFrame(cf)
		local comp = {cf:GetComponents()}
		local parts = {}
		for _, v in ipairs(comp) do
			table.insert(parts, string.format('%.6f', v))
		end
		return 'CFrame.new(' .. table.concat(parts, ', ') .. ')'
	end
	
	local function escapeStr(s)
		s = s:gsub('\\', '\\\\')
		s = s:gsub('"', '\\"')
		s = s:gsub("'", "\\'")
		s = s:gsub('\n', '\\n')
		s = s:gsub('\r', '\\r')
		return s
	end
	
	local function getEnumName(enumVal)
		local str = tostring(enumVal)
		return str:match('%.([%w_]+)$') or str
	end
	
	local function serializePoses(pose, lines, indent, parentVar)
		local varName = 'pose_' .. tostring(#lines + 1)
		local ind = string.rep('\t', indent)
		table.insert(lines, ind .. 'do')
		table.insert(lines, ind .. '\tlocal ' .. varName .. ' = Instance.new("Pose")')
		table.insert(lines, ind .. '\t' .. varName .. '.Name = "' .. escapeStr(pose.Name) .. '"')
		table.insert(lines, ind .. '\t' .. varName .. '.Weight = ' .. string.format('%.6f', pose.Weight))
		table.insert(lines, ind .. '\t' .. varName .. '.CFrame = ' .. serializeCFrame(pose.CFrame))
		table.insert(lines, ind .. '\t' .. varName .. '.EasingStyle = Enum.PoseEasingStyle.' .. getEnumName(pose.EasingStyle))
		table.insert(lines, ind .. '\t' .. varName .. '.EasingDirection = Enum.PoseEasingDirection.' .. getEnumName(pose.EasingDirection))
		for _, child in ipairs(pose:GetChildren()) do
			if child:IsA('Pose') then
				serializePoses(child, lines, indent + 1, varName)
			end
		end
		table.insert(lines, ind .. '\t' .. varName .. '.Parent = ' .. parentVar)
		table.insert(lines, ind .. 'end')
	end
	
	local function convertAnimation(assetId)
		local keyframeSeq = KeyframeSequenceProvider:GetKeyframeSequenceAsync('rbxassetid://' .. tostring(assetId))
		local lines = {}
		table.insert(lines, '-- ============================================')
		table.insert(lines, '-- KeyframeSequence Lua Script')
		table.insert(lines, '-- Generated from Animation Asset ID: ' .. tostring(assetId))
		table.insert(lines, '-- ============================================')
		table.insert(lines, '')
		table.insert(lines, 'local keyframeSequence = Instance.new("KeyframeSequence")')
		table.insert(lines, 'keyframeSequence.Name = "' .. escapeStr(keyframeSeq.Name) .. '"')
		table.insert(lines, 'keyframeSequence.Loop = ' .. tostring(keyframeSeq.Loop))
		table.insert(lines, 'keyframeSequence.Priority = Enum.AnimationPriority.' .. getEnumName(keyframeSeq.Priority))
		table.insert(lines, '')
		local keyframes = keyframeSeq:GetKeyframes()
		table.insert(lines, '-- Total Keyframes: ' .. #keyframes)
		table.insert(lines, '')
		for i, keyframe in ipairs(keyframes) do
			local kfVar = 'keyframe_' .. i
			table.insert(lines, '-- Keyframe ' .. i .. ' / ' .. #keyframes)
			table.insert(lines, 'do')
			table.insert(lines, '\tlocal ' .. kfVar .. ' = Instance.new("Keyframe")')
			table.insert(lines, '\t' .. kfVar .. '.Name = "' .. escapeStr(keyframe.Name) .. '"')
			table.insert(lines, '\t' .. kfVar .. '.Time = ' .. string.format('%.6f', keyframe.Time))
			table.insert(lines, '')
			local poses = keyframe:GetPoses()
			for _, pose in ipairs(poses) do
				serializePoses(pose, lines, 1, kfVar)
			end
			table.insert(lines, '')
			table.insert(lines, '\t' .. kfVar .. '.Parent = keyframeSequence')
			table.insert(lines, 'end')
			table.insert(lines, '')
		end
		table.insert(lines, '-- Place the KeyframeSequence')
		table.insert(lines, 'keyframeSequence.Parent = workspace')
		table.insert(lines, '')
		table.insert(lines, 'print("KeyframeSequence created successfully with ' .. #keyframes .. ' keyframes!")')
		return table.concat(lines, '\n')
	end
	
