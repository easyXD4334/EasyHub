-- SKIP RULES
-- ═══════════════════════════════════════════════════════════
local SKIP_PROPS = {
	Parent = true, Archivable = true, ClassName = true, DataCost = true,
	RobloxLocked = true, SourceAssetId = true, UniqueId = true,
	HistoryId = true, Tags = true,
}

local SKIP_CLASSES = {
	Player = true, Animator = true,
	PlayerScripts = true, PlayerGui = true, Backpack = true,
	StarCloudCollection = true, PackageLink = true,
}

-- ═══════════════════════════════════════════════════════════
-- SERIALISER
-- ═══════════════════════════════════════════════════════════
local output = {}
local varCounter = 0
local statusCallback = nil
local totalProcessed = 0

local function getVarName(instance: Instance): string
	varCounter += 1
	local safeName = instance.Name:gsub("%W", "_")
	if safeName == "" then safeName = "obj" end
	if safeName:match("^%d") then safeName = "_" .. safeName end
	return safeName .. "_" .. varCounter
end

local function emit(line: string)
	table.insert(output, line)
end

local function serialiseInstance(instance: Instance, parentVar: string, depth: number)
	if depth > MAX_DEPTH then return end
	if SKIP_CLASSES[instance.ClassName] then return end

	totalProcessed += 1
	if statusCallback and totalProcessed % 50 == 0 then
		statusCallback("Processing... (" .. totalProcessed .. " objects)")
		task.wait()
	end

	local varName = getVarName(instance)
	local className = instance.ClassName

	-- Create instance
	emit("")
	emit("local " .. varName .. " = Instance.new(" .. string.format("%q", className) .. ")")

	-- Gather properties
	local props = getClassProps(className)
	local propsToWrite = {}

	for _, propName in props do
		if SKIP_PROPS[propName] then continue end
		if propName == "Name" then
			if instance.Name ~= className and instance.Name ~= "" then
				table.insert(propsToWrite, {propName, instance.Name})
			end
			continue
		end

		local ok, val = pcall(function() return (instance :: any)[propName] end)
		if not ok then continue end
		if val == nil then continue end

		-- Skip Instance references (Part0/Part1/Adornee, etc.)
		if typeof(val) == "Instance" then continue end

		-- Compare against default
		local defVal = getDefault(className, propName)
		if defVal ~= nil and valuesEqual(val, defVal) then continue end

		table.insert(propsToWrite, {propName, val})
	end

	-- Also serialise Attributes
	local attributes = {}
	local ok2, attrs = pcall(function() return instance:GetAttributes() end)
	if ok2 and attrs then
		for attrName, attrVal in attrs do
			table.insert(attributes, {attrName, attrVal})
		end
	end

	-- Also serialise Tags
	local tags = {}
	local ok3, tagList = pcall(function() return instance:GetTags() end)
	if ok3 and tagList then
		for _, tag in tagList do
			table.insert(tags, tag)
		end
	end

	-- Write properties
	for _, entry in propsToWrite do
		local propName, val = entry[1], entry[2]
		local serialised = serialiseValue(val)
		emit(varName .. "." .. propName .. " = " .. serialised)
	end

	-- Write attributes
	for _, entry in attributes do
		local attrName, attrVal = entry[1], entry[2]
		local serialised = serialiseValue(attrVal)
		emit(varName .. ":SetAttribute(" .. string.format("%q", attrName) .. ", " .. serialised .. ")")
	end

	-- Write tags
	for _, tag in tags do
		emit(varName .. ":AddTag(" .. string.format("%q", tag) .. ")")
	end

	-- Set parent
	emit(varName .. ".Parent = " .. parentVar)

	-- Recurse children
	local children = instance:GetChildren()
	for _, child in children do
		serialiseInstance(child, varName, depth + 1)
	end
end

local function serialiseRoot(root: Instance): string
	output = {}
	varCounter = 0
	totalProcessed = 0

	emit("-- ═══════════════════════════════════════════")
	emit("-- Auto-generated Lua from Instance hierarchy")
	emit("-- Source: " .. root:GetFullName())
	emit("-- Generated: " .. os.date("%Y-%m-%d %H:%M:%S"))
	emit("-- ═══════════════════════════════════════════")
	emit("")

	-- If the root itself is a service / workspace, serialise its children directly
	local isService = root == game.Workspace or root:IsA("DataModel")
		or root:IsA("StarterGui") or root:IsA("ReplicatedStorage")
		or root:IsA("ServerStorage") or root:IsA("ServerScriptService")
		or root:IsA("Lighting") or root:IsA("ReplicatedFirst")
		or root:IsA("StarterPack") or root:IsA("StarterPlayer")
		or root:IsA("SoundService") or root:IsA("Teams")

	local rootVar
	if isService then
		rootVar = root:GetFullName():gsub("%.", "_"):gsub("%s", "_")
		if rootVar == "game" then rootVar = "game" end
		if root:IsA("Workspace") then
			emit('local targetParent = game:GetService("Workspace")')
			rootVar = "targetParent"
		elseif root:IsA("DataModel") then
			emit("-- DataModel children:")
			rootVar = "game"
		else
			local serviceName = root.ClassName
			emit('local targetParent = game:GetService("' .. serviceName .. '")')
			rootVar = "targetParent"
		end

		for _, child in root:GetChildren() do
			serialiseInstance(child, rootVar, 1)
		end
	else
		-- Need a parent reference for the root
		emit('local targetParent = workspace')
		rootVar = "targetParent"
		serialiseInstance(root, rootVar, 0)
	end

	return table.concat(output, "\n")
end

