	-- Resolve a path string like "game.Workspace.Model" to an instance
	local function resolvePath(pathStr: string): Instance?
		local parts = pathStr:split(".")
		if #parts == 0 then return nil end

		local current: any = nil
		if parts[1] == "game" then
			current = game
		elseif parts[1] == "workspace" or parts[1] == "Workspace" then
			current = game.Workspace
		else
			return nil
		end

		for i = 2, #parts do
			local name = parts[i]
			if current == game then
				-- Try GetService first
				local ok, svc = pcall(function() return game:GetService(name) end)
				if ok and svc then
					current = svc
				else
					local child = current:FindFirstChild(name)
					if child then
						current = child
					else
						return nil
					end
				end
			else
				local child = current:FindFirstChild(name)
				if child then
					current = child
				else
					return nil
				end
			end
		end

		return current
	end

