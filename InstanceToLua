	-- Convert helper
	performConversionFor = function(target: Instance)
		if not target or not target.Parent then
			statusLabel.Text = "❌ Instance no longer exists."
			statusLabel.TextColor3 = Color3.fromRGB(230, 70, 70)
			return
		end

		statusLabel.Text = "⏳ Converting..."
		statusLabel.TextColor3 = Color3.fromRGB(130, 180, 255)
		outputBox.Text = "-- Converting..."
		task.wait()

		local startTime = os.clock()

		-- Clean up old default cache
		for className, inst in defaultCache do
			if inst and typeof(inst) == "Instance" then
				pcall(function() inst:Destroy() end)
			end
		end
		defaultCache = {}
		propCache = {}

		local ok, result = pcall(function()
			return serialiseRoot(target)
		end)

		-- Clean up default instances
		for className, inst in defaultCache do
			if inst and typeof(inst) == "Instance" then
				pcall(function() inst:Destroy() end)
			end
		end
		defaultCache = {}

		local elapsed = os.clock() - startTime

		if ok then
			outputBox.Text = result
			local lineCount = 0
			for _ in result:gmatch("\n") do lineCount += 1 end
			lineCount += 1

			statusLabel.Text = string.format(
				"✅ Done! %d objects → %d lines  (%.2fs)",
				totalProcessed, lineCount, elapsed
			)
			statusLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
		else
			outputBox.Text = "-- ERROR:\n-- " .. tostring(result)
			statusLabel.Text = "❌ Error: " .. tostring(result):sub(1, 100)
			statusLabel.TextColor3 = Color3.fromRGB(230, 70, 70)
		end
	end

