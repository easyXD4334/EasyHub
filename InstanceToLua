	-- AUTO-DETECT: Watch Workspace for new Parts/Models
	-- ═══════════════════════════════════════════════
	local autoDetectEnabled = false
	local autoDetectConnection = nil

	local function runAutoConvert(child: Instance)
		-- Wait a brief moment for the instance to initialize (e.g. set its Name)
		task.wait(0.3)
		if not child.Parent then return end

		-- Check if already exists in the list
		for _, obj in detectedObjects do
			if obj == child then return end
		end

		-- Insert at the top of the list
		table.insert(detectedObjects, 1, child)

		-- Limit list size
		if #detectedObjects > 25 then
			table.remove(detectedObjects, #detectedObjects)
		end

		updateDetectedListUI()

		statusLabel.Text = "✨ Added to list: " .. child.Name
		statusLabel.TextColor3 = Color3.fromRGB(255, 200, 60)
	end

	local function toggleAutoDetect()
		autoDetectEnabled = not autoDetectEnabled

		if autoDetectEnabled then
			autoDetectBtn.Text = "  \u{1f7e2}  Auto-Detect: ON"
			autoDetectBtn.TextColor3 = Color3.fromRGB(80, 220, 120)
			autoDetectBtn.BackgroundColor3 = Color3.fromRGB(25, 50, 35)
			autoDetectStroke.Color = Color3.fromRGB(60, 150, 80)

			statusLabel.Text = "\u{1f441}\u{fe0f} Watching Workspace... add a Part or Model to populate list."
			statusLabel.TextColor3 = Color3.fromRGB(130, 180, 255)

			autoDetectConnection = game.Workspace.ChildAdded:Connect(function(child)
				if not autoDetectEnabled then return end
				-- Detect Parts (any BasePart) and Models, Folders, etc.
				if child:IsA("BasePart") or child:IsA("Model") or child:IsA("Folder") or child:IsA("Accessory") or child:IsA("Tool") then
					task.spawn(function()
						runAutoConvert(child)
					end)
				end
			end)
		else
			autoDetectBtn.Text = "  \u{26aa}  Auto-Detect: OFF"
			autoDetectBtn.TextColor3 = Color3.fromRGB(150, 150, 175)
			autoDetectBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
			autoDetectStroke.Color = Color3.fromRGB(50, 50, 70)

			statusLabel.Text = "Auto-detect disabled."
			statusLabel.TextColor3 = Color3.fromRGB(100, 100, 130)

			if autoDetectConnection then
				autoDetectConnection:Disconnect()
				autoDetectConnection = nil
			end
		end
	end

	autoDetectBtn.MouseButton1Click:Connect(toggleAutoDetect)

