-- ═══════════════════════════════════════════════════════════
-- COLLECT ALL PROPERTIES FOR A CLASS (walking hierarchy)
-- ═══════════════════════════════════════════════════════════
local propCache = {}

local function getClassProps(className: string): {string}
	if propCache[className] then return propCache[className] end

	local collected = {}
	local seen = {}

	local cur = className
	while cur do
		local list = PROP_DB[cur]
		if list then
			for _, prop in list do
				if not seen[prop] then
					seen[prop] = true
					table.insert(collected, prop)
				end
			end
		end
		cur = CLASS_PARENTS[cur]
	end

	-- Always ensure "Name" is present
	if not seen["Name"] then
		table.insert(collected, 1, "Name")
	end

	propCache[className] = collected
	return collected
end

-- ═══════════════════════════════════════════════════════════
-- DEFAULT VALUE COMPARISON
-- ═══════════════════════════════════════════════════════════
local defaultCache = {}

local CANNOT_CREATE = {
	Terrain = true, Workspace = true, Camera = true, Lighting = true,
	Players = true, StarterGui = true, StarterPack = true, StarterPlayer = true,
	ReplicatedFirst = true, ReplicatedStorage = true, ServerScriptService = true,
	ServerStorage = true, Teams = true, TestService = true,
	SoundService = true, Chat = true, TextChatService = true,
	LocalizationService = true, MaterialService = true,
}

local function getDefault(className: string, propName: string): any
	if CANNOT_CREATE[className] then return nil end

	if not defaultCache[className] then
		local ok, inst = pcall(Instance.new, className)
		if ok and inst then
			defaultCache[className] = inst
		else
			defaultCache[className] = false
			return nil
		end
	end

	local def = defaultCache[className]
	if not def then return nil end

	local ok, val = pcall(function() return (def :: any)[propName] end)
	if ok then return val end
	return nil
end

local function valuesEqual(a: any, b: any): boolean
	if typeof(a) ~= typeof(b) then return false end
	local t = typeof(a)

	if t == "CFrame" then
		local ca, cb = {a:GetComponents()}, {b:GetComponents()}
		for i = 1, #ca do
			if math.abs(ca[i] - cb[i]) > 1e-4 then return false end
		end
		return true
	elseif t == "Vector3" or t == "Vector2" then
		return (a - b).Magnitude < 1e-4
	elseif t == "Color3" then
		return math.abs(a.R - b.R) < 0.002 and math.abs(a.G - b.G) < 0.002 and math.abs(a.B - b.B) < 0.002
	elseif t == "UDim2" then
		return a.X.Scale == b.X.Scale and a.X.Offset == b.X.Offset
			and a.Y.Scale == b.Y.Scale and a.Y.Offset == b.Y.Offset
	elseif t == "UDim" then
		return a.Scale == b.Scale and a.Offset == b.Offset
	elseif t == "NumberSequence" or t == "ColorSequence" then
		local ka, kb = a.Keypoints, b.Keypoints
		if #ka ~= #kb then return false end
		for i = 1, #ka do
			if ka[i].Time ~= kb[i].Time then return false end
			if t == "NumberSequence" then
				if ka[i].Value ~= kb[i].Value or ka[i].Envelope ~= kb[i].Envelope then return false end
			else
				local va, vb = ka[i].Value, kb[i].Value
				if math.abs(va.R - vb.R) > 0.002 or math.abs(va.G - vb.G) > 0.002 or math.abs(va.B - vb.B) > 0.002 then return false end
			end
		end
		return true
	elseif t == "Rect" then
		return a.Min.X == b.Min.X and a.Min.Y == b.Min.Y and a.Max.X == b.Max.X and a.Max.Y == b.Max.Y
	elseif t == "NumberRange" then
		return a.Min == b.Min and a.Max == b.Max
	elseif t == "Font" then
		return tostring(a.Family) == tostring(b.Family) and a.Weight == b.Weight and a.Style == b.Style
	elseif t == "EnumItem" then
		return a == b
	elseif t == "PhysicalProperties" then
		return a.Density == b.Density and a.Friction == b.Friction and a.Elasticity == b.Elasticity
	else
		return a == b
	end
end

