-- ═══════════════════════════════════════════════════════════
-- TYPE SERIALISERS  (typeof → Lua literal string)
-- ═══════════════════════════════════════════════════════════
local serialiseValue  -- forward declaration

local function round(n, dp)
	dp = dp or 6
	local mult = 10 ^ dp
	return math.floor(n * mult + 0.5) / mult
end

local function numStr(n)
	if n == math.huge then return "math.huge" end
	if n == -math.huge then return "-math.huge" end
	if n ~= n then return "0/0" end
	local r = round(n)
	if r == math.floor(r) then
		return string.format("%g", r)
	else
		return string.format("%g", r)
	end
end

serialiseValue = function(value)
	local t = typeof(value)

	if t == "string" then
		return string.format("%q", value)

	elseif t == "number" then
		return numStr(value)

	elseif t == "boolean" then
		return tostring(value)

	elseif t == "nil" then
		return "nil"

	elseif t == "Vector2" then
		return string.format("Vector2.new(%s, %s)", numStr(value.X), numStr(value.Y))

	elseif t == "Vector3" then
		return string.format("Vector3.new(%s, %s, %s)", numStr(value.X), numStr(value.Y), numStr(value.Z))

	elseif t == "Vector2int16" then
		return string.format("Vector2int16.new(%d, %d)", value.X, value.Y)

	elseif t == "Vector3int16" then
		return string.format("Vector3int16.new(%d, %d, %d)", value.X, value.Y, value.Z)

	elseif t == "CFrame" then
		local c = {value:GetComponents()}
		local parts = {}
		for _, v in c do
			table.insert(parts, numStr(v))
		end
		return string.format("CFrame.new(%s)", table.concat(parts, ", "))

	elseif t == "Color3" then
		return string.format("Color3.new(%s, %s, %s)", numStr(value.R), numStr(value.G), numStr(value.B))

	elseif t == "BrickColor" then
		return string.format("BrickColor.new(%q)", value.Name)

	elseif t == "UDim" then
		return string.format("UDim.new(%s, %s)", numStr(value.Scale), numStr(value.Offset))

	elseif t == "UDim2" then
		return string.format("UDim2.new(%s, %s, %s, %s)",
			numStr(value.X.Scale), numStr(value.X.Offset),
			numStr(value.Y.Scale), numStr(value.Y.Offset))

	elseif t == "Rect" then
		return string.format("Rect.new(%s, %s, %s, %s)",
			numStr(value.Min.X), numStr(value.Min.Y),
			numStr(value.Max.X), numStr(value.Max.Y))

	elseif t == "NumberSequence" then
		local kps = {}
		for _, kp in value.Keypoints do
			if kp.Envelope == 0 then
				table.insert(kps, string.format("NumberSequenceKeypoint.new(%s, %s)", numStr(kp.Time), numStr(kp.Value)))
			else
				table.insert(kps, string.format("NumberSequenceKeypoint.new(%s, %s, %s)", numStr(kp.Time), numStr(kp.Value), numStr(kp.Envelope)))
			end
		end
		return string.format("NumberSequence.new({%s})", table.concat(kps, ", "))

	elseif t == "ColorSequence" then
		local kps = {}
		for _, kp in value.Keypoints do
			table.insert(kps, string.format(
				"ColorSequenceKeypoint.new(%s, Color3.new(%s, %s, %s))",
				numStr(kp.Time), numStr(kp.Value.R), numStr(kp.Value.G), numStr(kp.Value.B)
			))
		end
		return string.format("ColorSequence.new({%s})", table.concat(kps, ", "))

	elseif t == "NumberRange" then
		return string.format("NumberRange.new(%s, %s)", numStr(value.Min), numStr(value.Max))

	elseif t == "Ray" then
		return string.format("Ray.new(Vector3.new(%s, %s, %s), Vector3.new(%s, %s, %s))",
			numStr(value.Origin.X), numStr(value.Origin.Y), numStr(value.Origin.Z),
			numStr(value.Direction.X), numStr(value.Direction.Y), numStr(value.Direction.Z))

	elseif t == "Faces" then
		local f = {}
		if value.Top then table.insert(f, "Enum.NormalId.Top") end
		if value.Bottom then table.insert(f, "Enum.NormalId.Bottom") end
		if value.Left then table.insert(f, "Enum.NormalId.Left") end
		if value.Right then table.insert(f, "Enum.NormalId.Right") end
		if value.Front then table.insert(f, "Enum.NormalId.Front") end
		if value.Back then table.insert(f, "Enum.NormalId.Back") end
		return string.format("Faces.new(%s)", table.concat(f, ", "))

	elseif t == "Axes" then
		local a = {}
		if value.X then table.insert(a, "Enum.Axis.X") end
		if value.Y then table.insert(a, "Enum.Axis.Y") end
		if value.Z then table.insert(a, "Enum.Axis.Z") end
		return string.format("Axes.new(%s)", table.concat(a, ", "))

	elseif t == "PhysicalProperties" then
		return string.format("PhysicalProperties.new(%s, %s, %s, %s, %s)",
			numStr(value.Density), numStr(value.Friction), numStr(value.Elasticity),
			numStr(value.FrictionWeight), numStr(value.ElasticityWeight))

	elseif t == "Font" then
		return string.format("Font.new(%q, Enum.FontWeight.%s, Enum.FontStyle.%s)",
			tostring(value.Family), value.Weight.Name, value.Style.Name)

	elseif t == "EnumItem" then
		return string.format("Enum.%s.%s", tostring(value.EnumType), value.Name)

	elseif t == "Instance" then
		return "nil --[[ Instance ref: " .. value:GetFullName() .. " ]]"

	elseif t == "Region3" then
		return "nil --[[ Region3 (not constructable from properties) ]]"

	elseif t == "Region3int16" then
		return "nil --[[ Region3int16 ]]"

	elseif t == "PathWaypoint" then
		return string.format("PathWaypoint.new(Vector3.new(%s, %s, %s), Enum.PathWaypointAction.%s)",
			numStr(value.Position.X), numStr(value.Position.Y), numStr(value.Position.Z),
			value.Action.Name)

	elseif t == "DateTime" then
		return string.format("DateTime.fromUnixTimestamp(%d)", value.UnixTimestamp)

	elseif t == "TweenInfo" then
		return "nil --[[ TweenInfo (runtime only) ]]"

	elseif t == "RaycastParams" then
		return "nil --[[ RaycastParams (runtime only) ]]"

	elseif t == "OverlapParams" then
		return "nil --[[ OverlapParams (runtime only) ]]"

	elseif t == "FloatCurveKey" then
		return string.format("FloatCurveKey.new(%s, %s, Enum.KeyInterpolationMode.%s)",
			numStr(value.Time), numStr(value.Value), value.Interpolation.Name)

	elseif t == "RotationCurveKey" then
		local cf = value.Value
		local c = {cf:GetComponents()}
		local parts = {}
		for _, v in c do table.insert(parts, numStr(v)) end
		return string.format("RotationCurveKey.new(%s, CFrame.new(%s), Enum.KeyInterpolationMode.%s)",
			numStr(value.Time), table.concat(parts, ", "), value.Interpolation.Name)

	elseif t == "SharedTable" then
		return "nil --[[ SharedTable ]]"

	elseif t == "Content" then
		local s = tostring(value)
		if s == "" then return '""' end
		return string.format("%q", s)

	elseif t == "Secret" then
		return "nil --[[ Secret ]]"

	else
		local ok, str = pcall(tostring, value)
		if ok then
			return string.format("%q --[[ %s ]]", str, t)
		else
			return string.format("nil --[[ unserializable: %s ]]", t)
		end
	end
end

