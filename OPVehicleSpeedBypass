-- ===================== PHYSICS BOOST LOGIC =====================

local Workspace = game:GetService("Workspace")

local function getCharacterParts()
	local character = player.Character
	if not character then return nil end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not rootPart then return nil end
	return humanoid, rootPart
end

-- Returns the seat the humanoid is currently sitting in, if any, restricted
-- to VehicleSeat (PVC/regular Seats are ignored - we only "drive" vehicles).
local function getVehicleSeat(humanoid)
	local seatPart = humanoid and humanoid.SeatPart
	if seatPart and seatPart:IsA("VehicleSeat") then
		return seatPart
	end
	return nil
end

-- Finds the part to actually push with BodyVelocity when driving a vehicle:
-- prefer the assembly's PrimaryPart if the model has one set, otherwise the
-- seat part itself (BodyVelocity affects the whole connected assembly via
-- welds/joints regardless of which single part it's parented to).
local function getVehicleDrivePart(seatPart)
	local model = seatPart:FindFirstAncestorOfClass("Model")
	if model and model.PrimaryPart then
		return model.PrimaryPart
	end
	return seatPart
end

-- Builds a camera-relative move direction from the WASD / mobile D-pad state.
-- Returns nil if nothing is held. Used for BOTH on-foot and in-vehicle
-- movement, so "look left, move left" works identically in a vehicle.
local function getKeyboardMoveDirection()
	local x = 0
	local z = 0
	if moveState.Forward then z -= 1 end
	if moveState.Back then z += 1 end
	if moveState.Left then x -= 1 end
	if moveState.Right then x += 1 end

	if x == 0 and z == 0 then
		return nil
	end

	local camera = Workspace.CurrentCamera
	local camCF = camera and camera.CFrame or CFrame.new()
	-- flatten camera look/right vectors onto the XZ plane so pitch doesn't matter
	local lookFlat = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z)
	local rightFlat = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z)
	if lookFlat.Magnitude < 0.001 then
		lookFlat = Vector3.new(0, 0, -1)
	end
	lookFlat = lookFlat.Unit
	rightFlat = (rightFlat.Magnitude < 0.001) and Vector3.new(1, 0, 0) or rightFlat.Unit

	local direction = (lookFlat * -z) + (rightFlat * x)
	if direction.Magnitude < 0.001 then
		return nil
	end
	return direction.Unit
end

startBoost = function()
	local humanoid, rootPart = getCharacterParts()
	if not humanoid or not rootPart then return end

	if bodyVelocity then
		bodyVelocity:Destroy()
	end

	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.Name = "PhysicsSpeedBoost"
	bodyVelocity.MaxForce = Vector3.new(currentMaxForce, 0, currentMaxForce)
	bodyVelocity.Velocity = Vector3.new(0, 0, 0)
	bodyVelocity.P = 1250
	bodyVelocity.Parent = rootPart

	local attachedTo = rootPart -- tracks whatever part bodyVelocity currently lives on

	if heartbeatConn then
		heartbeatConn:Disconnect()
	end

	heartbeatConn = RunService.Heartbeat:Connect(function()
		local hum, root = getCharacterParts()
		if not hum or not root or not bodyVelocity then
			stopBoost()
			return
		end

		local seatPart = getVehicleSeat(hum)
		local targetPart = seatPart and getVehicleDrivePart(seatPart) or root

		-- if the boost target changed (entered/exited a vehicle), move the
		-- BodyVelocity to the new part instead of recreating it every frame
		if targetPart ~= attachedTo then
			bodyVelocity.Parent = targetPart
			attachedTo = targetPart
		end

		bodyVelocity.MaxForce = Vector3.new(currentMaxForce, 0, currentMaxForce)

		-- Same camera-relative direction whether walking or driving -
		-- look left and the boost pushes left, in both cases.
		local direction = getKeyboardMoveDirection()
		bodyVelocity.Velocity = direction and (direction * currentSpeed) or Vector3.new(0, 0, 0)
	end)
end

stopBoost = function()
	if heartbeatConn then
		heartbeatConn:Disconnect()
		heartbeatConn = nil
	end
	if bodyVelocity then
		bodyVelocity:Destroy()
		bodyVelocity = nil
	end
end

toggleButton.MouseButton1Click:Connect(function()
	boostEnabled = not boostEnabled
	if boostEnabled then
		toggleButton.Text = "Disable Boost"
		toggleButton.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
		startBoost()
	else
		toggleButton.Text = "Enable Boost"
		toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 90)
		stopBoost()
	end
end)

-- Pull live slider values every frame so dragging instantly affects the boost
RunService.Heartbeat:Connect(function()
	currentSpeed = speedSlider:GetAttribute("Value") or currentSpeed
	currentMaxForce = forceSlider:GetAttribute("Value") or currentMaxForce
end)

-- Re-apply the boost after respawning, if it was left on
player.CharacterAdded:Connect(function()
	if boostEnabled then
		task.wait(1)
		startBoost()
	end
end)
