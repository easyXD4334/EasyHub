local currentSpeed = DEFAULT_SPEED
local currentMaxForce = DEFAULT_MAXFORCE
local bodyVelocity = nil
local heartbeatConn = nil

local startBoost  -- forward declarations
local stopBoost

-- WASD + on-screen mobile button state, all merged into one table.
-- Movement direction is computed from this instead of Humanoid.MoveDirection
-- so it responds the instant a key/button is pressed.
local moveState = {
	Forward = false,  -- W
	Back = false,     -- S
	Left = false,      -- A
	Right = false,     -- D
}

local KEY_TO_MOVE = {
	[Enum.KeyCode.W] = "Forward",
	[Enum.KeyCode.S] = "Back",
	[Enum.KeyCode.A] = "Left",
	[Enum.KeyCode.D] = "Right",
}

-- ===================== GUI =====================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "PhysicsSpeedBoostGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

-- ---- WASD keybind detection ----
-- NOTE: gameProcessedEvent is true both when typing in a TextBox AND when
-- sitting in a VehicleSeat (the seat's built-in drive script consumes WASD).
-- We only want to ignore the former, so check TextBox focus explicitly
-- instead of trusting gameProcessedEvent.
local function isTypingInTextBox()
	local focused = UserInputService:GetFocusedTextBox()
	return focused ~= nil
end

UserInputService.InputBegan:Connect(function(input, _gameProcessedEvent)
	if isTypingInTextBox() then return end
	local moveKey = KEY_TO_MOVE[input.KeyCode]
	if moveKey then
		moveState[moveKey] = true
	end
end)

UserInputService.InputEnded:Connect(function(input, _gameProcessedEvent)
	local moveKey = KEY_TO_MOVE[input.KeyCode]
	if moveKey then
		-- always clear on release, so a key doesn't get stuck "held" if
		-- focus changed mid-press (e.g. clicked into a textbox while holding W)
		moveState[moveKey] = false
	end
end)

