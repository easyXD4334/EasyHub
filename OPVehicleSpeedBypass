local DEFAULT_MAXFORCE = 100000     -- how strongly velocity is enforced
-- No upper/lower limit is enforced anymore - type any number you want.
-- These two are only used to size the slider bar's visual range; typing
-- a value outside this range still works and just pins the knob to an end.
local SPEED_SLIDER_MAX = 666
local FORCE_SLIDER_MAX = 666666

-- ===================== STATE =====================
