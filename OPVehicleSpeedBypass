-- ---- drag-to-move support (grab the title bar) ----
-- Standard Roblox drag pattern: track the offset between where the pointer
-- went down and the frame's position, then re-apply that offset every time
-- the pointer moves, for as long as the same input is held down.
do
	local dragging = false
	local dragStart = nil   -- Vector3/Vector2 input position when drag began
	local startPos = nil    -- frame.Position when drag began

	local function update(input)
		local delta = input.Position - dragStart
		startPos = startPos or frame.Position
		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end

	title.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = frame.Position

			-- if the input ends (mouse released / touch lifted) anywhere,
			-- even outside the title label, stop dragging
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	title.InputChanged:Connect(function(input)
		if dragging
			and (input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch) then
			update(input)
		end
	end)

	-- also listen globally so dragging keeps tracking even if the pointer
	-- moves off the title label while still held down
	UserInputService.InputChanged:Connect(function(input)
		if dragging
			and (input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch) then
			update(input)
		end
	end)
end

-- ---- reusable slider builder (slider + synced typeable textbox) ----
local function createSlider(yPos, labelText, minVal, maxVal, defaultVal)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, -20, 0, 50)
	container.Position = UDim2.new(0, 10, 0, yPos)
	container.BackgroundTransparency = 1
	container.Parent = frame

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, -60, 0, 20)
	label.BackgroundTransparency = 1
	label.Text = labelText
	label.TextColor3 = Color3.new(1, 1, 1)
	label.Font = Enum.Font.Gotham
	label.TextSize = 14
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = container

	-- typeable value box, top-right of the slider
	local inputBox = Instance.new("TextBox")
	inputBox.Size = UDim2.new(0, 55, 0, 20)
	inputBox.Position = UDim2.new(1, -55, 0, 0)
	inputBox.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
	inputBox.TextColor3 = Color3.new(1, 1, 1)
	inputBox.Font = Enum.Font.Gotham
	inputBox.TextSize = 13
	inputBox.Text = tostring(defaultVal)
	inputBox.ClearTextOnFocus = false
	inputBox.Parent = container

	local inputBoxCorner = Instance.new("UICorner")
	inputBoxCorner.CornerRadius = UDim.new(0, 4)
	inputBoxCorner.Parent = inputBox

	local sliderBack = Instance.new("Frame")
	sliderBack.Size = UDim2.new(1, 0, 0, 8)
	sliderBack.Position = UDim2.new(0, 0, 0, 28)
	sliderBack.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	sliderBack.BorderSizePixel = 0
	sliderBack.Parent = container

	local sliderBackCorner = Instance.new("UICorner")
	sliderBackCorner.CornerRadius = UDim.new(1, 0)
	sliderBackCorner.Parent = sliderBack

	local pct = (defaultVal - minVal) / (maxVal - minVal)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(pct, 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
	fill.BorderSizePixel = 0
	fill.Parent = sliderBack

	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(1, 0)
	fillCorner.Parent = fill

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 16, 0, 16)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(pct, 0, 0.5, 0)
	knob.BackgroundColor3 = Color3.new(1, 1, 1)
	knob.BorderSizePixel = 0
	knob.ZIndex = 2
	knob.Parent = sliderBack

	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(1, 0)
	knobCorner.Parent = knob

	local dragging = false

	-- single source of truth: sets fill/knob/textbox/attribute from a numeric value.
	-- The VALUE itself is never clamped - only the knob/fill position is clamped
	-- so the slider graphic doesn't break when you type something outside
	-- the visual range (e.g. Speed = 5000).
	local function setValue(value, fromTextBox)
		local relX = math.clamp((value - minVal) / (maxVal - minVal), 0, 1)
		fill.Size = UDim2.new(relX, 0, 1, 0)
		knob.Position = UDim2.new(relX, 0, 0.5, 0)
		if not fromTextBox then
			inputBox.Text = tostring(value)
		end
		container:SetAttribute("Value", value)
	end

	local function updateFromDrag(input)
		local relX = math.clamp(
			(input.Position.X - sliderBack.AbsolutePosition.X) / sliderBack.AbsoluteSize.X,
			0, 1
		)
		local value = math.floor(minVal + (maxVal - minVal) * relX)
		setValue(value)
	end

	local function isPointer(input)
		return input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch
	end

	knob.InputBegan:Connect(function(input)
		if isPointer(input) then dragging = true end
	end)

	sliderBack.InputBegan:Connect(function(input)
		if isPointer(input) then
			dragging = true
			updateFromDrag(input)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging
			and (input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch) then
			updateFromDrag(input)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if isPointer(input) then dragging = false end
	end)

	-- typing support: commit on Enter or when the box loses focus
	inputBox.FocusLost:Connect(function()
		local typed = tonumber(inputBox.Text)
		if typed then
			setValue(math.floor(typed), true)
			inputBox.Text = tostring(container:GetAttribute("Value"))
		else
			-- invalid input -> revert to current value
			inputBox.Text = tostring(container:GetAttribute("Value"))
		end
	end)

	container:SetAttribute("Value", defaultVal)
	return container
end

