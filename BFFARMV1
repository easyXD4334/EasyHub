		tweenCancelFlag = false

		local function tweenFunc()
			local rootPart = character:FindFirstChild("HumanoidRootPart")
			if not rootPart then return end

			local startPos = rootPart.Position

			local currentSpeed = INITIAL_MOVE_SPEED

			while true do
				if tweenCancelFlag then break end
				if not character.Parent then break end
				local rootPart = character:FindFirstChild("HumanoidRootPart")
				if not rootPart then break end

				local currentPos = rootPart.Position
				local distanceToTarget = (targetPosition - currentPos).Magnitude

				-- Check for speed boost
				if distanceToTarget < BOOST_DISTANCE then
					currentSpeed = BOOSTED_MOVE_SPEED
				else
					currentSpeed = INITIAL_MOVE_SPEED
				end

				-- If close enough, snap to target and break
				local dt = task.wait()
				if distanceToTarget < currentSpeed * dt then
					character:PivotTo(CFrame.new(targetPosition))
					break
				end

				-- Move towards target
				local step = currentSpeed * dt
				local moveVec = (targetPosition - currentPos).Unit * step
				local newPos = currentPos + moveVec
				character:PivotTo(CFrame.new(newPos))
			end
			currentTweenCoroutine = nil
		end

		currentTweenCoroutine = coroutine.create(tweenFunc)
		coroutine.resume(currentTweenCoroutine)
	end

	local function TextLabelToVector3(textLabel)
		if not textLabel or not textLabel.Text then
			warn("Invalid TextLabel")
			return Vector3.new()
		end

		-- Split the text by commas
		local parts = string.split(textLabel.Text, ",")
		if #parts < 3 then
			warn("Text must be in format: X, Y, Z")
			return Vector3.new()
		end

		-- Convert parts to numbers
		local x = tonumber(parts[1])
		local y = tonumber(parts[2])
		local z = tonumber(parts[3])

		if not (x and y and z) then
			warn("Text must contain valid numbers")
			return Vector3.new()
		end

		return Vector3.new(x, y, z)
	end

	local function getNearestMob()
		local myCharacter = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
		local myPivot = myCharacter:GetPivot().Position

		local nearestPlayer = nil
		local nearestDistance = math.huge

		for i, player in workspace.Enemies:GetChildren() do
			if player ~= LocalPlayer and player:FindFirstChild("Humanoid") and player.Humanoid.Health > 0 then
				local pivot = player:GetPivot().Position
				local distance = (pivot - myPivot).Magnitude
				if distance < nearestDistance then
					nearestDistance = distance
					nearestPlayer = player
				end
			end
		end

		return nearestPlayer
	end

	local Data = script.Parent.Data

	function GotoNearestMob()
		local Mob = getNearestMob()
		if Mob then
			local TargetPosition = Mob:GetPivot().Position
			while true do
				if Data.FarmNearestMob.Text == "0" then
					break
				end
				if Mob.Humanoid and Mob.Humanoid.Health > 0 then
					moveCharacterTo(LocalPlayer.Character, TargetPosition + Vector3.new(0,15,10))
					--Move mob in 400 stunds towards the mob
					for _,OtherMob in workspace.Enemies:GetChildren() do
						local Length = (OtherMob:GetPivot().Position - TargetPosition).Magnitude
						if Length < 400 then
							moveCharacterTo(OtherMob, TargetPosition)
						end
					end

					task.wait()
				else
					break
				end
			end
		end
	end

	-- Function to handle the click event

	function Start(Mode,Bool)
		if Mode == "FarmNearestMob" then
			if Bool then
				while Data.FarmNearestMob.Text == "1" do
					GotoNearestMob()
					wait()
				end
			else
				StopTween()
			end
		end
	end

	local buttons = {}

	for _, button in script.Parent:GetDescendants() do
		if button:IsA("TextButton") and Data:FindFirstChild(button.Text) then
			local Option = Data:FindFirstChild(button.Text)
			if Option.Text == "0" then
				button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			else
				button.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
			end
			button.MouseButton1Click:Connect(function()
				if Option.Text == "0" then
					Option.Text = "1"
					button.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
				else
					Option.Text = "0"
					button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
				end
			end)
		end
	end

	for _,Option in Data:GetChildren() do
		if Option:IsA("TextLabel") then
			Option:GetPropertyChangedSignal("Text"):Connect(function()
				if Option.Text == "1" then

					Start(Option.Name,true)

					--buttons[Option].BackgroundColor3 = Color3.fromRGB(0, 255, 0)
				else
					Start(Option.Name,false)

					--buttons[Option].BackgroundColor3 = Color3.fromRGB(0, 0, 0)
				end
			end)
		end
	end
