local function ICCI_fake_script() -- Fake Script: ServerStorage.BFFarm.Frame.NPC.TPTweeningHandle
	local script = Instance.new("LocalScript")
	script.Name = "TPTweeningHandle"
	script.Parent = Converted["_NPC1"]
	local req = require
	local require = function(obj)
		local fake = fake_module_scripts[obj]
		if fake then
			return fake()
		end
		return req(obj)
	end

	local tpFrame = script.Parent

	local Players = game:GetService("Players")
	local LocalPlayer = Players.LocalPlayer

	local INITIAL_MOVE_SPEED = 365 -- studs per second
	local BOOSTED_MOVE_SPEED = INITIAL_MOVE_SPEED * 1.5 -- studs per second
	local BOOST_DISTANCE = 400 -- studs

	tpFrame.Parent.Setting.AFrame.TextBox.Changed:Connect(function()
		INITIAL_MOVE_SPEED = tonumber(tpFrame.Parent.Setting.AFrame.TextBox.Text) or 10
		BOOSTED_MOVE_SPEED = INITIAL_MOVE_SPEED * 1.5 
	end)

	tpFrame.Parent.Setting.BFrame.TextBox.Changed:Connect(function()
		BOOST_DISTANCE = tonumber(tpFrame.Parent.Setting.BFrame.TextBox.Text) or 0
	end)

	local currentTweenCoroutine = nil
	local tweenCancelFlag = false

	-- Function to stop current tween
	local function StopTween()
		tweenCancelFlag = true
		if currentTweenCoroutine then
			-- Coroutine will exit on next loop
			currentTweenCoroutine = nil
		end
	end

	-- Function to smoothly move character to target position, with speed boost when close
	local function moveCharacterTo(character, targetPosition)
		StopTween() -- Cancel any previous tween
		tweenCancelFlag = false

		local function tweenFunc()
			local rootPart = character:FindFirstChild("HumanoidRootPart")
			if not rootPart then return end

			local startPos = rootPart.Position

			local currentSpeed = INITIAL_MOVE_SPEED

			while true do
				if tweenCancelFlag then break end
				if not character.Parent then break end
				local rootPart = character:FindFirstChild("HumanoidRootPart")
				if not rootPart then break end

				local currentPos = rootPart.Position
				local distanceToTarget = (targetPosition - currentPos).Magnitude

				-- Check for speed boost
				if distanceToTarget < BOOST_DISTANCE then
					currentSpeed = BOOSTED_MOVE_SPEED
				else
					currentSpeed = INITIAL_MOVE_SPEED
				end

				-- If close enough, snap to target and break
				local dt = task.wait()
				if distanceToTarget < currentSpeed * dt then
					character:PivotTo(CFrame.new(targetPosition))
					break
				end

				-- Move towards target
				local step = currentSpeed * dt
				local moveVec = (targetPosition - currentPos).Unit * step
				local newPos = currentPos + moveVec
				character:PivotTo(CFrame.new(newPos))
			end
			currentTweenCoroutine = nil
		end

		currentTweenCoroutine = coroutine.create(tweenFunc)
		coroutine.resume(currentTweenCoroutine)
	end

	-- Listen for Event fired from TpPlr buttons
	local TPEvent = tpFrame.Event
	TPEvent.Event:Connect(function(targetPosition)
		-- Loop through all players and tween the one whose root part matches the position
		for _, player in Players:GetPlayers() do
			if player.Character then
				local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
				if rootPart and rootPart.Position == targetPosition then
					moveCharacterTo(player.Character, targetPosition)
				end
			end
		end
	end)

	local function TextLabelToVector3(textLabel)
		if not textLabel or not textLabel.Text then
			warn("Invalid TextLabel")
			return Vector3.new()
		end

		-- Split the text by commas
		local parts = string.split(textLabel.Text, ",")
		if #parts < 3 then
			warn("Text must be in format: X, Y, Z")
			return Vector3.new()
		end

		-- Convert parts to numbers
		local x = tonumber(parts[1])
		local y = tonumber(parts[2])
		local z = tonumber(parts[3])

		if not (x and y and z) then
			warn("Text must contain valid numbers")
			return Vector3.new()
		end

		return Vector3.new(x, y, z)
	end


	-- Connect all TPTweening buttons
	for _, child in tpFrame:GetChildren() do
		if child:IsA("TextButton") then
			local valueObj = child:FindFirstChildWhichIsA("TextLabel")
			if valueObj then
				child.MouseButton1Click:Connect(function()
					if LocalPlayer and LocalPlayer.Character then
						wait(.1)
						moveCharacterTo(LocalPlayer.Character, TextLabelToVector3(valueObj))
					end
				end)
			end
		end
	end

	-- Connect StopTween button
	local stopButton = tpFrame.A
	if stopButton and stopButton:IsA("TextButton") then
		stopButton.MouseButton1Click:Connect(function()
			StopTween()
		end)
	end


end
