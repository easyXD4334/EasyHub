local function getCurrentCash()
    local leaderstats = LP:FindFirstChild("leaderstats")
    local cash = leaderstats and leaderstats:FindFirstChild("Cash")
    return (cash and (cash:IsA("IntValue") or cash:IsA("NumberValue"))) and cash.Value or 0
end

-- Format numbers with commas (e.g., 1000000 -> 1,000,000)
local function formatNumber(value)
    local left, num, right = string.match(tostring(value), '^([^%d]*%d+)(%d*)(.-)$')
    return left .. (num:reverse():gsub('(%d%d%d)', '%1,'):reverse()) .. right
end

-- ───────────────────────────────────────────────
--          Auto-Rejoin on Error / Disconnect
-- ───────────────────────────────────────────────
local function onErrorMessageChanged(errorMessage)
    if errorMessage and errorMessage ~= "" then
        print("Error detected: " .. errorMessage)
        if LP then
            task.wait(1) 
            TeleportService:Teleport(game.PlaceId, LP)
        end
    end
end
GuiService.ErrorMessageChanged:Connect(onErrorMessageChanged)

