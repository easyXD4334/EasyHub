-- Helper Functions
local function notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 4
        })
    end)
end

local function getCharacter() return LP.Character or LP.CharacterAdded:Wait() end
local function getHumanoid() return getCharacter():WaitForChild("Humanoid") end
local function getRoot() return getCharacter():WaitForChild("HumanoidRootPart") end

local function getVehicle()
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hum or not hum.SeatPart or not hum.SeatPart:IsA("VehicleSeat") then return nil end
    return hum.SeatPart:FindFirstAncestorWhichIsA("Model")
end

local function getCurrentCarModel()
    local humanoid = getHumanoid()
    local carsFolder = Workspace:FindFirstChild("Cars")
    if not carsFolder then return nil end
    for _, seat in ipairs(carsFolder:GetDescendants()) do
        if seat:IsA("VehicleSeat") and seat.Occupant == humanoid then
            return seat:FindFirstAncestorOfClass("Model")
        end
    end
    return nil
end

local function anchorVehicle(veh, anchored)
    for _, part in ipairs(veh:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Anchored = anchored
        end
    end
end

local function teleportVehicleOrCharacter(destinationCFrame)
    local veh = getVehicle()
    if veh and veh.PrimaryPart then
        local partsToUnanchor = {}
        for _, obj in ipairs(veh:GetDescendants()) do
            if obj:IsA("BasePart") and not obj.Anchored then
                table.insert(partsToUnanchor, obj)
                obj.Anchored = true
            end
        end
        
        veh:PivotTo(destinationCFrame)
        task.wait(0.1)
        
        for _, part in ipairs(partsToUnanchor) do
            if part and part.Parent then part.Anchored = false end
        end
    else
        local root = getRoot()
        if root then root.CFrame = destinationCFrame end
    end
end

local function findBillboard(model)
    return model:FindFirstChild("TrailerDeliveryCashBillboard", true)
end

local function findCashLabel(billboard)
    for _, d in ipairs(billboard:GetDescendants()) do
        if d:IsA("TextLabel") and d.Text:find("%$") then return d end
    end
end

local function anyPart(model)
    return model:FindFirstChildWhichIsA("BasePart", true)
end

local function parseMoney(txt)
    return tonumber((tostring(txt or ""):gsub("%$", ""):gsub(",", ""))) or 0
end

local function getBestTrailer()
    local root = getRoot()
    if not root then return nil end
    
    local bestTrailer, bestDist, bestAmount = nil, math.huge, -1
    
    for _, model in ipairs(jobTrailersFolder:GetChildren()) do
        if model:IsA("Model") then
            local bb = findBillboard(model)
            local lbl = bb and findCashLabel(bb)
            if lbl then
                local amount = parseMoney(lbl.Text)
                if amount > 0 then
                    local part = anyPart(model)
                    if part then
                        local dist = (part.Position - root.Position).Magnitude
                        if amount > bestAmount or (amount == bestAmount and dist < bestDist) then
                            bestAmount = amount
                            bestDist = dist
                            bestTrailer = model
                        end
                    end
                end
            end
        end
    end
    return bestTrailer, bestDist, bestAmount
end

local function getDeliveryCFrame()
    local countdown = Workspace:FindFirstChild("DestinationCountdown", true)
    if not countdown then return nil end
    local primary = countdown.Parent
    if not primary or primary.Name ~= "Primary" then return nil end
    
    if primary:IsA("BasePart") then return primary.CFrame end
    local altPart = primary:FindFirstChildWhichIsA("BasePart", true)
    return altPart and altPart.CFrame
end

local function getTrailerAnchor(trailerModel)
    if not trailerModel or not trailerModel:IsA("Model") then return nil end
    return trailerModel:FindFirstChild("HoldPart", true) or trailerModel:FindFirstChild("TrailerMain", true)
end

local function isValidJobTrailer(trailerModel)
    return trailerModel and trailerModel:IsA("Model") 
        and trailerModel:FindFirstChild("TrailerMain", true) 
        and trailerModel:FindFirstChild("HoldPart", true)
end

local function findNearestJobTrailer(maxDistance)
    local root = getRoot()
    local bestTrailer, bestDist = nil, math.huge
    for _, inst in ipairs(jobTrailersFolder:GetChildren()) do
        if isValidJobTrailer(inst) then
            local anchor = getTrailerAnchor(inst)
            if anchor then
                local dist = (anchor.Position - root.Position).Magnitude
                if dist <= maxDistance and dist < bestDist then
                    bestDist = dist
                    bestTrailer = inst
                end
            end
        end
    end
    return bestTrailer, bestDist
end

local function waitForCarTrailer(car, timeoutSeconds)
    local t0 = os.clock()
    while os.clock() - t0 < timeoutSeconds do
        local tr = car:FindFirstChild("Trailer")
        if tr then return tr end
        task.wait(0.05)
    end
    return nil
end

