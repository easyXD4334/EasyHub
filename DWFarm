local function updateMoneyDisplay()
    local current = getCurrentCash()
    local sessionTime = os.clock() - sessionStartTime
    local avgPerSec = sessionTime > 0 and (totalSessionGain / sessionTime) or 0
    
    moneyLabel.Text = string.format(
        "Current Cash: $%s\nLast Job Gain: $%s\nTotal Session Gain: $%s\nJobs Completed: %d\nAverage Cash/s: $%.2f",
        formatNumber(current),
        formatNumber(lastJobGain),
        formatNumber(totalSessionGain),
        jobsCompleted,
        avgPerSec
    )
end

