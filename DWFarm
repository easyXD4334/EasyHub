-- =========================
-- Main Farm Loop
-- =========================
local function autoLoop()
    while AUTO_RUNNING do
        local veh = getVehicle()
        local car = getCurrentCarModel()
        
        if not veh or not veh.PrimaryPart or not car then
            statusLabel.Text = "Sit in a vehicle to start auto."
            task.wait(1)
            continue
        end
        
        local cashBefore = getCurrentCash()
        
        statusLabel.Text = "Finding best trailer..."
        local trailer, dist, amount = getBestTrailer()
        if not trailer then
            statusLabel.Text = "No valid trailer found. Waiting..."
            task.wait(3)
            continue
        end
        
        local part = anyPart(trailer)
        if not part then continue end
        
        statusLabel.Text = string.format("TP to trailer ($%d, ~%d studs)", amount, math.floor(dist))
        teleportVehicleOrCharacter(part.CFrame * CFrame.new(0, 27, 15) * CFrame.Angles(0, math.pi, 0))
        task.wait(0.6)
        
        statusLabel.Text = "Attaching trailer..."
        local nearestTrailer, nearestDist = findNearestJobTrailer(MAX_DISTANCE)
        if not nearestTrailer or nearestDist > MAX_DISTANCE then
            statusLabel.Text = "No trailer nearby after TP."
            task.wait(2)
            continue
        end
        
        attachEvent:FireServer(nearestTrailer)
        
        task.delay(0.05, function()
            local npc = Gui:Get("NPCDialog")
            if npc then npc:Open("Hi, that's my trailer!", "TrailerPrompt", nil, nearestTrailer) end
        end)
        task.wait(1)
        
        statusLabel.Text = "Starting job..."
        local carTrailer = waitForCarTrailer(car, 2.5)
        if not carTrailer then
            statusLabel.Text = "Trailer attach timeout."
            task.wait(2)
            continue
        end
        startEvent:FireServer(carTrailer)
        task.wait(0.6)
        
        -- Step 4: Drive at Y=500, then drop to delivery zone
        statusLabel.Text = "Driving to delivery..."
        local targetCF = getDeliveryCFrame()
        if not targetCF then
            statusLabel.Text = "No delivery zone found."
            task.wait(2)
            continue
        end
        
        local targetPos = targetCF.Position
        local startPos = veh.PrimaryPart.Position
        
        local flatTarget = Vector3.new(targetPos.X, 500, targetPos.Z)
        local flatStart = Vector3.new(startPos.X, 500, startPos.Z)
        
        local totalDist = (flatTarget - flatStart).Magnitude
        
        if totalDist > 1 then
            local startTime = os.clock()
            anchorVehicle(veh, true)
            
            local direction = (flatTarget - flatStart).Magnitude > 0.1 and (flatTarget - flatStart).Unit or Vector3.new(0,0,1)
            
            while AUTO_RUNNING do
                local timePassed = os.clock() - startTime
                local distTraveled = timePassed * DRIVE_SPEED
                
                if distTraveled >= totalDist then break end
                
                local newPos = flatStart + direction * distTraveled
                
                veh:PivotTo(CFrame.new(newPos, newPos + direction))
                task.wait(0.01)
            end
            
            anchorVehicle(veh, false)
            
            if not AUTO_RUNNING then break end
        end
        
        -- FIX: Always teleport to delivery zone after tween (drops from Y=500 to actual delivery Y)
        local finalPos = Vector3.new(targetPos.X, targetPos.Y, targetPos.Z)
        teleportVehicleOrCharacter(CFrame.new(finalPos, finalPos + targetCF.LookVector))
        
        statusLabel.Text = "Completing job..."
        task.wait(1)
        completeEvent:FireServer()
        task.wait(1.2)
        
        local cashAfter = getCurrentCash()
        lastJobGain = cashAfter - cashBefore
        if lastJobGain > 0 then
            totalSessionGain += lastJobGain
            jobsCompleted += 1
            notify("Job Complete", "Gained $" .. lastJobGain, 4)
        end
    end
    statusLabel.Text = "Auto stopped."
end

local function toggleAuto(forceState)
    if forceState ~= nil then
        AUTO_RUNNING = forceState
    else
        AUTO_RUNNING = not AUTO_RUNNING
    end
    
    if AUTO_RUNNING then
        autoToggleButton.Text = "STOP AUTO"
        autoToggleButton.BackgroundColor3 = Color3.fromRGB(255, 60, 60)
        autoTask = task.spawn(autoLoop)
    else
        autoToggleButton.Text = "START AUTO"
        autoToggleButton.BackgroundColor3 = Color3.fromRGB(60, 120, 255)
        if autoTask then
            autoTask = nil
        end
    end
end

